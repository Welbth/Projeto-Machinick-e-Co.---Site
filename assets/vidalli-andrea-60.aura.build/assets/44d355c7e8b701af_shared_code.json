      <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Innenanstrich</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Fassadengestaltung</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Tapezierarbeiten</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Bodenbeläge</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Lackieren</a></li>\n                    </ul>\n                </div>\n                \n                <div>\n                    <h4 class=\"text-slate-900 font-semibold text-sm mb-5\">Über uns</h4>\n                    <ul class=\"space-y-3 text-xs text-slate-500 font-medium\">\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Unser Team</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Karriere / Jobs</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Partner</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Referenzen</a></li>\n                    </ul>\n                </div>\n                \n                <div>\n                    <h4 class=\"text-slate-900 font-semibold text-sm mb-5\">Rechtliches</h4>\n                    <ul class=\"space-y-3 text-xs text-slate-500 font-medium\">\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Impressum</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Datenschutz</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">AGB</a></li>\n                        <li><a href=\"#\" class=\"hover:text-sky-600 transition-colors\">Cookie Einstellungen</a></li>\n                    </ul>\n                </div>\n            </div>\n            \n            <div class=\"border-t border-slate-100 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-xs text-slate-400\">\n                    &copy; 2024 Haus des Malers GmbH. Alle Rechte vorbehalten.\n                </p>\n                <div class=\"flex gap-6\">\n                    <span class=\"flex items-center gap-2 text-xs text-slate-400\">\n                        <span class=\"w-2 h-2 rounded-full bg-green-500\"></span>\n                        Status: Betriebsbereit\n                    </span>\n                </div>\n            </div>\n        </div>\n    </footer>\n\n</body>\n</html>","private":false,"user_id":"536771f6-2efa-4ea8-902c-f0e89885d4bd","share_source_code":true}]