div>\n                        \n                        <div class=\"flex items-start gap-4 group\">\n                            <div class=\"w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400 group-hover:text-sky-500 group-hover:bg-sky-50 transition-colors shrink-0\">\n                                <iconify-icon icon=\"solar:map-point-linear\" width=\"24\"></iconify-icon>\n                            </div>\n                            <div>\n                                <div class=\"text-sm font-medium text-slate-900 mb-1\">Besuchen Sie uns</div>\n                                <span class=\"text-slate-600 block\">Farbenstraße 1</span>\n                                <span class=\"text-slate-600 block\">10115 Berlin</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Form -->\n                <div class=\"bg-white p-8 md:p-10 rounded-3xl border border-slate-100 shadow-xl shadow-slate-200/40\">\n                    <form class=\"space-y-5\">\n                        <div class=\"grid grid-cols-2 gap-5\">\n                            <div class=\"space-y-1.5\">\n                                <label for=\"first-name\" class=\"text-xs font-semibold text-slate-700 ml-1\">Vorname</label>\n                                <input type=\"text\" id=\"first-name\" class=\"w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-400\" placeholder=\"Max\">\n                            </div>\n                            <div class=\"space-y-1.5\">\n                                <label for=\"last-name\" class=\"text-xs font-semibold text-slate-700 ml-1\">Nachname</label>\n                                <input type=\"text\" id=\"last-name\" class=\"w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-400\" placeholder=\"Mustermann\">\n                            </div>\n                        </div>\n\n                        <div class=\"space-y-1.5\">\n                            <label for=\"email\" class=\"text-xs font-semibold text-slate-700 ml-1\">E-Mail</label>\n                            <input type=\"email\" id=\"email\" class=\"w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-400\" placeholder=\"max@beispiel.de\">\n                        </div>\n\n                        <div class=\"space-y-1.5\">\n                            <label for=\"service\" class=\"text-xs font-semibold text-slate-700 ml-1\">Worum geht es?</label>\n                            <div class=\"relative\">\n                                <select id=\"service\" class=\"w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all appearance-none text-slate-600 cursor-pointer\">\n                                    <option>Innenanstrich</option>\n                                    <option>Fassadenarbeiten</option>\n                                    <option>Lackieren</option>\n                                    <option>Boden verlegen</option>\n                                    <option>Sonstiges</option>\n                                </select>\n                                <div class=\"absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none\">\n                                    <iconify-icon icon=\"solar:alt-arrow-down-linear\" width=\"14\"></iconify-icon>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"space-y-1.5\">\n                            <label for=\"message\" class=\"text-xs font-semibold text-slate-700 ml-1\">Nachricht</label>\n                            <textarea id=\"message\" rows=\"4\" class=\"w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-400 resize-none\" placeholder=\"Wie können wir Ihnen helfen?\"></textarea>\n                        </div>\n\n                        <div class=\"flex items-start gap-3 pt-2\">\n                             <div class=\"relative flex items-center mt-0.5\">\n                                <input type=\"checkbox\" id=\"privacy\" class=\"peer h-4 w-4 cursor-pointer appearance-none rounded border border-slate-300 bg-white checked:bg-sky-500 checked:border-sky-500 transition-all\">\n                                <span class=\"pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-white opacity-0 peer-checked:opacity-100\">\n                                    <iconify-icon icon=\"solar:check-read-linear\" width=\"12\"></iconify-icon>\n                                </span>\n                            </div>\n                            <label for=\"privacy\" class=\"text-xs text-slate-500 leading-tight select-none cursor-pointer\">\n                                Ich stimme der Datenschutzerklärung zu.\n                            </label>\n                        </div>\n\n                        <button type=\"button\" class=\"w-full bg-sky-500 hover:bg-sky-600 text-white text-sm font-medium py-3.5 rounded-xl transition-all shadow-lg shadow-sky-500/20 mt-2 flex items-center justify-center gap-2\">\n                            Nachricht absenden\n                            <iconify-icon icon=\"solar:plain-3-bold\" width=\"16\"></iconify-icon>\n                        </button>\n                    </form>\n                </div>\n            </div>\n        </div>\