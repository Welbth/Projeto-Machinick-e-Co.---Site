      <span class=\"text-sky-600 font-medium text-xs tracking-wider uppercase mb-2 block\">Was wir tun</span>\n                <h2 class=\"text-3xl font-semibold text-slate-900 tracking-tight mb-4\">Unser Handwerk</h2>\n                <p class=\"text-slate-500 font-light\">\n                    Wir bieten umfassende Lösungen für Innen- und Außenbereiche. Mit hochwertigen Materialien und modernster Technik.\n                </p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                <!-- Card 1 -->\n                <div class=\"bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-sky-100/50 hover:-translate-y-1 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 mb-6\">\n                        <iconify-icon icon=\"solar:paint-roller-bold-duotone\" width=\"24\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-lg font-semibold text-slate-900 mb-2\">Malerarbeiten Innen</h3>\n                    <p class=\"text-sm text-slate-500 leading-relaxed\">\n                        Präzise Anstriche, Lackierarbeiten und kreative Wandtechniken für Ihr Wohlfühlzuhause.\n                    </p>\n                </div>\n\n                <!-- Card 2 -->\n                <div class=\"bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-sky-100/50 hover:-translate-y-1 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-500 mb-6\">\n                        <iconify-icon icon=\"solar:home-bold-duotone\" width=\"24\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-lg font-semibold text-slate-900 mb-2\">Fassadengestaltung</h3>\n                    <p class=\"text-sm text-slate-500 leading-relaxed\">\n         