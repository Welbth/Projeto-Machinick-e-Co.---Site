s://images.unsplash.com/photo-1574359411659-15573a27fd0c?q=80&w=2569&auto=format&fit=crop\" class=\"object-cover w-full h-full group-hover:scale-105 transition-transform duration-700\" alt=\"Facade\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-8\">\n                        <div>\n                             <span class=\"inline-block px-2 py-1 bg-white/20 backdrop-blur-md rounded text-[10px] text-white font-medium mb-2\">Außenbereich</span>\n                            <p class=\"text-white font-medium text-lg\">Fassadenanstrich Weiß</p>\n                        </div>\n                    </div>\n                </div>\n                \n                <!-- Project 4 CTA -->\n                <div class=\"group relative overflow-hidden rounded-2xl bg-sky-50 border border-sky-100 aspect-[4/3] flex flex-col items-center justify-center p-8 text-center\">\n                    <div class=\"w-16 h-16 bg-white rounded-full flex items-center justify-center text-sky-500 mb-6 shadow-sm group-hover:scale-110 transition-transform duration-300\">\n                        <iconify-icon icon=\"solar:paint-roller-bold-duotone\" width=\"28\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-slate-900 mb-3\">Ihr Projekt als nächstes?</h3>\n                    <p class=\"text-slate-500 text-sm mb-8 max-w-xs mx-auto\">Kontaktieren Sie uns für eine unverbindliche Beratung vor Ort.</p>\n                    <a href=\"#kontakt\" class=\"bg-sky-500 hover:bg-sky-600 text-white text-sm font-medium h-10 px-6 rounded-full transition-all flex items-center justify-center\">\n                        Jetzt anfragen\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Testimonial -->\n    <section class=\"py-24 bg-gradient-to-b from-slate-50 to-white border-y border-slate-100\">\n        <div class=\"max-w-4xl mx-auto px-6 text-center\">\n            <div class=\"inline-flex gap-1 text-orange-400 mb-6\">\n                <iconify-icon icon=\"solar:star-bold\" width=\"20\"></iconify-icon>\n                <iconify-icon icon=\"solar:star-bold\" width=\"20\"></iconify-icon>\n                <iconify-icon icon=\"solar:star-bold\" width=\"20\"></iconify-icon>\n                <iconify-icon icon=\"solar:star-bold\" width=\"20\"></iconify-icon>\n                <iconify-icon icon=\"solar:star-bold\" width=\"20\"></iconify-icon>\n            </div>\n            <blockquote class=\"text-xl md:text-3xl font-medium text-slate-900 leading-tight mb-8\">\n                \"Endlich ein Handwerker, der hält was er verspricht. Super sauber gearbeitet, freundliches Team und das Ergebnis ist perfekt.\"\n            </blockquote>\n            <div class=\"flex items-center justify-center gap-3\">\n                <div class=\"w-10 h-10 bg-sky-100 rounded-full flex items-center justify-center text-sky-600 font-bold text-sm\">S</div>\n                <div class=\"text-left\">\n                    <div class=\"font-semibold text-slate-900 text-sm\">Sandra Weiss</div>\n                    <div class=\"text-slate-400 text-xs\">Privatkundin, Hamburg</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact Section -->\n    <section id=\"kontakt\" class=\"py-20 md:py-32 bg-white\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24\">\n                <div>\n                    <span class=\"text-sky-600 font-medium text-xs tracking-wider uppercase mb-2 block\">Kontakt</span>\n                    <h2 class=\"text-3xl font-semibold text-slate-900 tracking-tight mb-6\">Wir freuen uns auf Sie</h2>\n                    <p class=\"text-slate-500 mb-10 font-light leading-relaxed\">\n                        Egal ob