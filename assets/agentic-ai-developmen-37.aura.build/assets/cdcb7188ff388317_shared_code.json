   <div class=\"hidden md:block\">\n                <h1 class=\"text-xs tracking-[0.2em] font-medium uppercase leading-tight\">Abyss<br>Diving Club</h1>\n            </div>\n        </div>\n\n        <div class=\"hidden lg:flex gap-12 pt-1 text-[0.65rem] tracking-[0.2em] font-medium uppercase\">\n            <a href=\"#experiences\" class=\"hover:opacity-50 transition-opacity\">Experiences</a>\n            <a href=\"#expeditions\" class=\"hover:opacity-50 transition-opacity\">Expeditions</a>\n            <a href=\"#membership\" class=\"hover:opacity-50 transition-opacity\">Membership</a>\n            <a href=\"#journal\" class=\"hover:opacity-50 transition-opacity\">Journal</a>\n            <a href=\"#about\" class=\"hover:opacity-50 transition-opacity\">About</a>\n        </div>\n\n        <div class=\"flex items-center gap-6 pt-1 text-[0.65rem] tracking-[0.2em] font-medium uppercase\">\n            <a href=\"#login\" class=\"hidden md:block hover:opacity-50 transition-opacity\">Member Login</a>\n            <button class=\"w-4 h-4 border border-white rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-colors\" aria-label=\"Menu\">\n                <i data-lucide=\"circle\" class=\"w-2 h-2\"></i>\n            </button>\n        </div>\n    </nav>\n\n    <!-- SECTION 1: HERO (Perfect Rebuild) -->\n    <section class=\"relative min-h-screen w-full pt-32 pb-24 px-6 md:px-12 flex flex-col justify-center\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 h-full relative z-10 w-full max-w-[1800px] mx-auto\">\n            \n            <!-- Left Content Column -->\n            <div class=\"col-span-1 lg:col-span-5 flex flex-col justify-center relative z-20 mt-12 lg:mt-0\">\n                <div class=\"text-[0.65rem] tracking-[0.2em] font-medium mb-16 lg:mb-24 flex items-center gap-4\">\n                    <span>01</span>\n                    <span class=\"w-4 h-[1px] bg-black opacity-30\"></span>\n                    <span class=\"opacity-50\">05</span>\n                </div>\n\n                <h2 class=\"text-6xl md:text-8xl font-medium tracking-tight uppercase leading-[0.95] mb-16\">\n                    Depth<br>Beyond<br>Ordinary\n                </h2>\n\n                <div class=\"flex flex-col sm:flex-row items-start sm:items-end gap-8 mb-32 lg:mb-0\">\n                    <div class=\"relative pl-6\">\n                        <div class=\"absolute left-0 top-0 w-3 h-3 border-t border-l border-black\"></div>\n                        <p class=\"text-[0.65rem] tracking-[0.2em] uppercase font-medium max-w-[200px] leading-relaxed\">\n                            A global community for those who seek the extraordinary underwater.\n                        </p>\n                    </div>\n                    \n                    <a href=\"#discover\" class=\"group flex items-center gap-4 text-[0.65rem] tracking-[0.2em] uppercase font-medium pb-1 border-b border-black\">\n                        Discover More\n                        <span class=\"transform group-hover:rotate-90 transition-transform duration-300\">+</span>\n                    </a>\n                </div>\n            </div>\n\n            <!-- Right Image Column (Clipped) -->\n            <div class=\"col-span-1 lg:col-span-7 absolute inset-0 lg:relative lg:inset-auto h-[60vh] lg:h-[85vh] w-full z-0 lg:z-10 mt-24 lg:mt-0 opacity-40 lg:opacity-100 mix-blend-multiply lg:mix-blend-normal\">\n                <!-- Using a wrapper to apply the clip path so the image covers it properly -->\n                <div class=\"w-full h-full hero-clip bg-black overflow-hidden relative\">\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg\" alt=\"Cave diver in cenote\" class=\"w-full h-full object-cover object-center scale-105 hover:scale-100 transition-transform duration-1000\">\n                    \n                    <!-- Internal Overlay elements within the image area -->\n                    <div class=\"absolute right-8 top-1/2 transform -translate-y-1/2 flex flex-col items-center gap-6 text-white z-20 hidden lg:flex\">\n                        <span class=\"text-[0.65rem] font-mono tracking-widest vertical-text transform rotate-180\">23.4241° N</span>\n                        <div class=\"w-[1px] h-16 bg-white opacity-30\"></div>\n                        <span class=\"text-[0.65rem] tracking-[0.3em] font-medium uppercase vertical-text transform rotate-180\">Explore</span>\n                        <div class=\"w-[1px] h-16 bg-white opacity-30\"></div>\n                        <span class=\"text-[0.65rem] font-mono tracking-widest vertical-text transform rotate-180\">77.0928° E</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Absolute Positioned Elements overlapping grid -->\n        \n        <!-- Bottom Left Black Block -->\n        <div class=\"absolute bottom-0 left-0 w-full lg:w-[45%] bg-[#0A0A0A] text-white p-8 md:p-12 z-30 flex flex-col md:flex-row gap-8 items-start md:items-center\">\n            <div class=\"w-24 h-24 overflow-hidden flex-shrink-0\">\n                <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4734259a-bad7-422f-981e-ce01e79184f2_1600w.jpg\" alt=\"Manta Ray\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700\">\n            </div>\n            <ul class=\"text-[0.65rem] tracking-[0.15em] font-medium uppercase space-y-4 w-full\">\n                <li class=\"flex items-center gap-4\"><span class=\"w-4 h-[1px] bg-white opacity-50\"></span> Curated Dive Experiences</li>\n                <li class=\"flex items-center gap-4\"><span class=\"w-4 h-[1px] bg-white opacity-50\"></span> Worldwide Expeditions</li>\n                <li class=\"flex items-center gap-4\"><span class=\"w-4 h-[1px] bg-white opacity-50\"