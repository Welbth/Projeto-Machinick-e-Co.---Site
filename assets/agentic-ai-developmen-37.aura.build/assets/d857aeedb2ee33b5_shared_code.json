er -->\n        <div class=\"relative z-20 h-full w-full flex flex-col lg:flex-row\">\n            \n            <!-- Left Content -->\n            <div class=\"w-full lg:w-[45%] h-full pt-32 pb-12 px-6 md:px-12 flex flex-col justify-center text-black\">\n                <div class=\"mb-8 flex items-center gap-3 text-xs tracking-[0.15em] uppercase font-medium\">\n                    <i data-lucide=\"play\" class=\"w-3 h-3 fill-current\"></i>\n                    <div>\n                        <span class=\"block\">Premium Yachts</span>\n                        <span class=\"block text-black/60\">Curated to perfection</span>\n                    </div>\n                </div>\n\n                <h1 class=\"text-6xl md:text-8xl lg:text-[7rem] leading-[0.9] tracking-tight-override font-normal mb-16\">\n                    BEYOND<br/>\n                    THE HORIZON\n                </h1>\n\n                <div class=\"mt-auto md:mt-0 flex items-center justify-between border-b border-black/20 pb-4 max-w-sm group cursor-pointer\">\n                    <span class=\"text-xs uppercase tracking-widest font-medium group-hover:pl-2 transition-all\">Explore Yachts</span>\n                    <i data-lucide=\"arrow-up-right\" class=\"w-4 h-4 group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform\"></i>\n                </div>\n            </div>\n\n            <!-- Right Content Overlay -->\n            <div class=\"hidden lg:block absolute top-32 right-32 z-20 text-white/60 text-[10px] tracking-widest uppercase font-mono text-right\">\n                <div class=\"mb-2\">Lat<br/><span class=\"text-white\">36.7627° N</span></div>\n                <div class=\"mb-4\">Lon<br/><span class=\"text-white\">-122.1694° W</span></div>\n                <i data-lucide=\"crosshair\" class=\"w-4 h-4 ml-auto opacity-50\"></i>\n            </div>\n\n            <!-- Bottom Left Counter -->\n            <div class=\"absolute bottom-12 left-6 md:left-12 z-20 text-black flex items-end gap-4 mix-blend-difference\" style=\"color: white;\">\n                <div class=\"text-5xl font-light tracking-tight-override\">01</div>\n                <div class=\"text-xs mb-2 opacity-60 tracking-widest\">/ 05</div>\n                <div class=\"w-32 h-[1px] bg-white/20 mb-3 ml-4 relative hidden md:block\">\n                    <div class=\"absolute left-0 top-0 h-full w-1/5 bg-white\"></div>\n                </div>\n            </div>\n\n            <!-- Bottom Right Thumbnails -->\n            <div class=\"absolute bottom-12 right-32 z-20 hidden lg:flex gap-3 items-center\">\n                <div class=\"w-16 h-10 border border-white p-0.5 cursor-pointer opacity-100 transition-opacity\">\n                    <img src=\"https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?q=80&w=200&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale\" />\n                </div>\n                <div class=\"w-16 h-10 border border-transparent p-0.5 cursor-pointer opacity-50 hover:opacity-100 transition-opacity\">\n                    <img src=\"https://images.unsplash.com/photo-1605281317010-fe5ffe798166?q=80&w=200&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale\" />\n                </div>\n                <div class=\"w-16 h-10 border border-transparent p-0.5 cursor-pointer opacity-50 hover:opacity-100 transition-opacity\">\n                    <img src=\"https://images.unsplash.com/photo-1540946485063-a40da27545f8?q=80&w=200&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale\" />\n                </div>\n                <div class=\"w-16 h-10 border border-transparent p-0.5 cursor-pointer opacity-50 hover:opacity-100 transition-opacity\">\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg\" class=\"w-full h-full object-cover grayscale\" />\n                </div>\n                <button class=\"w-8 h-8 rounded-full bg-white text-black flex items-center justify-center ml-2 hover:scale-110 transition-transform\">\n                    <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n                </button>\n            </div>\n        </div>\n\n        <!-- Extreme Right Vertical Bar -->\n        <div class=\"hidden 2xl:flex absolute right-0 top-0 h-full w-24 bg-[#111] border-l border-white/5 flex-col items-center justify-between py-12 z-30 grid-texture relative\">\n            <div class=\"absolute inset-0 bg-black/50 z-0\"></div>\n            <div class=\"text-white/40 text-xs tracking-widest z-10\">01</div>\n            <div class=\"z-10\" style=\"writing-mode: vertical-rl; text-orientation: mixed;\">\n                <span class=\"text-6xl tracking-[0.2em] text-white/20 uppercase font-light\">Northsea</span>\n            </div>\n            \n            <!-- Circular Stamp SVG -->\n            <div class=\"relative w-16 h-16 z-10 spin-slow\">\n                <svg viewBox=\"0 0 100 100\" class=\"w-full h-full overflow-visible fill-white/40\">\n                    <path id=\"curve\" d=\"M 50 50 m -40 0 a 40 40 0 1 1 80 0 a 40 40 0 1 1 -80 0\" fill=\"transparent\"/>\n                    <text class=\"text-[10px] tracking-[0.3em] uppercase\"><textPath href=\"#curve\">Northsea Yachts • Excellence At Sea • </textPath></text>\n                </svg>\n                <div class=\"absolute inset-0 flex items-center justify-center\">\n                    <i data-lucide=\"anchor\" class=\"w-4 h-4 text-white/40\"></i>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 2: SPECIFICATIONS DATA -->\n    <section class=\"py-24 px-6 md:px-12 border-b border-white/10 bg-[#0a0a0a]\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-6\">\n            <div class=\"flex flex-col border-l border-white/20 pl-6\">\n                <span class=\"text-xs uppercase tracking-widest text-white/40 mb-4\">Total Length</span>\n                <span class=\"text-4xl md:text-5xl font-light tracking-tight-override\">115<span class=\"text-xl text-white/40 ml-1\">M</span></span>\n            </div>\n            <div class=\"flex flex-col border-l border-white/20 pl-6\">\n                <span class=\"text-xs uppercase tracking-widest text-white/40 mb-4\">Cruising Speed</span>\n                <span class=\"text-4xl md:text-5xl font-light tracking-tight-override\">18<span class=\"text-xl text-white/40 ml-1\">KN</span></span>\n            </div>\n            <div class=\"flex flex-col border-l border-white/20 pl-6\">\n                <span class=\"text-xs uppercase tracking-widest text-white/40 mb-4\">Guests</span>\n                <span class=\"text-4xl md:text-5xl font-light tracking-tight-override\">24<span class=\"text-xl text-white/40 ml-1\">PAX</span></span>\n            </div>\n            <div class=\"flex flex-col border-l border-white/20 pl-6\">\n                <span class=\"text-xs uppercase tracking-widest text-white/40 mb-4\">Range</span>\n                <span class=\"text-4xl md:text-5xl font-light tracking-tight-override\">6000<span class=\"text-xl text-white/40 ml-1\">NM</span></span>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 3: THE FLEET (Horizontal Scroll) -->\n    <section id=\"yachts\" class=\"py-32 pl-6 md:pl-12 overflow-hidden bg-[#0a0a0a]\">\n        <div class=\"flex items-end justify-between pr-6 md:pr-12 mb-16\">\n            <div>\n                <h2 class=\"text-xs uppercase tracking-widest text-white/60 mb-4\">02 / Collection</h2>\n                <h3 class=\"text-4xl md:text-5xl font-normal tracking-tight-override\">CURATED FLEET</h3>\n            </div>\n            <div class=\"hidden md:flex gap-4\">\n                <button class=\"w-12 h-12 border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition-colors rounded-full\">\n                    <i data-lucide=\"arrow-left\" class=\"w-5 h-5\"></i>\n                </button>\n                <button class=\"w-12 h-12 border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition-colors rounded-full\">\n                    <i data-lucide=\"arrow-right\" class=\"w-5 h-5\"></i>\n                </button>\n            </div>\n        </div>\n\n        <div class=\"flex gap-8 overflow-x-auto hide-scrollbar pr-12 pb-8 cursor-grab active:cursor-grabbing\">\n            <!-- Card 1 -->\n            <div class=\"min-w-[85vw] md:min-w-[600px] group\">\n                <div class=\"relative h-[400px] w-full overflow-hidden mb-6 bg-white/5\">\n                    <img src=\"https://images.unsplash.com/photo-1605281317010-fe5ffe798166?q=80&w=800&auto=format&fit=crop\" alt=\"Yacht 1\" class=\"w-full h-full object-cover grayscale opacity-80 group-hover:scale-105 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700\" />\n                    <div class=\"absolute top-4 right-4 bg-black/80 backdrop-blur-sm px-4 py-2 text-xs tracking-widest uppercase border border-white/10\">For Sale</div>\n                </div>\n                <div class=\"flex justify-between items-start border-b border-white/10 pb-6\">\n                    <div>\n                        <h4 class=\"text-2xl font-normal tracking-tight-override mb-2\">AETHER</h4>\n                        <p class=\"text-lg text-white/50\">Lürssen • 2023</p>\n                    </div>\n                    <div class=\"text-right\">\n                        <div class=\"text-lg font-normal\">€85,000,000</div>\n                        <div class=\"text-xs tracking-widest text-white/40 mt-1 uppercase\">85m / 278ft</div>\n                    </div>\n                </div>\n            </div>\n            \n            <!-- Card 2 -->\n            <div class=\"min-w-[85vw] md:min-w-[600px] group\">\n                <div class=\"relative h-[400px] w-full overflow-hidden mb-6 bg-white/5\">\n                    <img src=\"https://images.unsplash.com/photo-1540946485063-a40da27545f8?q=80&w=800&auto=format&fit=crop\" alt=\"Yacht 2\" class=\"w-full h-full object-cover grayscale opacity-80 group-hover:scale-105 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700\" />\n                    <div class=\"absolute top-4 right-4 bg-white text-black px-4 py-2 text-xs tracking-widest uppercase\">Charter</div>\n                </div>\n                <div class=\"flex justify-between items-start border-b border-white/10 pb-6\">\n                    <div>\n                        <h4 class=\"text-2xl font-normal tracking-tight-override mb-2\">SOLARIS</h4>\n                        <p class=\"text-lg text-white/50\">Feadship • 2021</p>\n                    </div>\n                    <div class=\"text-right\">\n                        <div class=\"text-lg font-normal\">From €1,200,000 / wk</div>\n                        <div class=\"text-xs tracking-widest text-white/40 mt-1 uppercase\">102m / 335ft</div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Card 3 -->\n            <div class=\"min-w-[85vw] md:min-w-[600px] group\">\n                <div class=\"relative h-[400px] w-full overflow-hidden mb-6 bg-white/5 flex items-center justify-center border border-white/10\">\n                   <div class=\"text-center\">\n                       <i data-lucide=\"ship\" class=\"w-8 h-8 text-white/40 mx-auto mb-4\"></i>\n                       <span class=\"text-xs uppercase tracking-widest text-white/60\">View All 42 Yachts</span>\n                   </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 4: FULL WIDTH EDITORIAL -->\n    <section class=\"relative h-[80vh] w-full flex items-center justify-center overflow-hidden\">\n        <div class=\"absolute inset-0\">\n            <img src=\"https://images.unsplash.com/photo-1520255870062-bd79d3865de7?q=80&w=2000&auto=format&fit=crop\" alt=\"Ocean Wake\" class=\"w-full h-full object-cover object-center opacity-60 grayscale\" />\n            <div class=\"absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-transparent to-[#0a0a0a]\"></div>\n        </div>\n        <div class=\"relative z-10 text-center max-w-4xl px-6\">\n            <h2 class=\"text-xs uppercase tracking-[0.3em] text-white/60 mb-8\">03 / The Experience</h2>\n            <p class=\"text-3xl md:text-5xl font-light tracking-tight-override leading-tight\">\n                \"We don't just broker transactions; we architect maritime legacies for those who demand the absolute pinnacle of engineering and design.\"\n            </p>\n            <button class=\"mt-12 border-b border-white pb-2 text-xs uppercase tracking-widest hover:text-white/60 hover:border-white/60 transition-all\">Discover Our Story</button>\n        </div>\n    </section>\n\n    <!-- SECTION 5: SERVICES (Bento Grid) -->\n    <section id=\"services\" class=\"py-32 px-6 md:px-12 bg-[#0a0a0a]\">\n        <h2 class=\"text-xs uppercase tracking-widest text-white/60 mb-16 text-center\">04 / Expertise</h2>\n        \n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n            <!-- Box 1 -->\n            <div class=\"lg:col-span-2 border border-white/10 bg-[#111] p-12 hover:bg-[#151515] transition-colors group\">\n                <i data-lucide=\"compass\" class=\"w-8 h-8 mb-32 text-white/40 group-hover:text-white transition-colors\"></i>\n                <h3 class=\"text-3xl font-normal tracking-tight-override mb-4\">Brokerage</h3>\n                <p class=\"text-lg text-white/50 max-w-md mb-8\">Navigating the complex global market to acquire or sell your asset with unmatched discretion and precision.</p>\n                <div class=\"w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all\">\n                    <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i>\n                </div>\n            </div>\n            \n            <!-- Box 2 -->\n            <div class=\"border border-white/10 bg-[#111] p-12 hover:bg-[#151515] transition-colors group\">\n                <i data-lucide=\"anchor\" class=\"w-8 h-8 mb-32 text-white/40 group-hover:text-white transition-colors\"></i>\n                <h3 class=\"text-2xl font-normal tracking-tight-override mb-4\">Charter</h3>\n                <p class=\"text-lg text-white/50 mb-8\">Curating bespoke itineraries across the world's most exclusive destinations.</p>\n            </div>\n\n            <!-- Box 3 -->\n            <div class=\"border border-white/10 bg-[#111] p-12 hover:bg-[#151515] transition-colors group\">\n                <i data-lucide=\"wrench\" class=\"w-8 h-8 mb-32 text-white/40 group-hover:text-white transition-colors\"></i>\n                <h3 class=\"text-2xl font-normal tracking-tight-override mb-4\">Management</h3>\n                <p class=\"text-lg text-white/50 mb-8\">Comprehensive operational, technical, and financial administration of your vessel.</p>\n            </div>\n\n            <!-- Box 4 -->\n            <div class=\"lg:col-span-2 border border-white/10 bg-[#111] p-12 hover:bg-[#151515] transition-colors group relative overflow-hidden\">\n                <div class=\"absolute inset-0 opacity-10 grayscale mix-blend-overlay\">\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4734259a-bad7-422f-981e-ce01e79184f2_1600w.jpg\" class=\"w-full h-full object-cover\" />\n                </div>\n                <div class=\"relative z-10\">\n                    <i data-lucide=\"hammer\" class=\"w-8 h-8 mb-32 text-white/40 group-hover:text-white transition-colors\"></i>\n                    <h3 class=\"text-3xl font-normal tracking-tight-override mb-4\">New Build</h3>\n                    <p class=\"text-lg text-white/50 max-w-md mb-8\">From blank canvas to launch, we oversee the conception and construction of custom masterpieces.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 6: TECHNICAL / ENGINEERING -->\n    <section class=\"py-32 relative bg-[#050505] overflow-hidden border-y border-white/10\">\n        <div class=\"absolute inset-0 grid-texture opacity-20\"></div>\n        \n        <div class=\"max-w-7xl mx-auto px-6 md:px-12 relative z-10 flex flex-col lg:flex-row items-center gap-16\">\n            <div class=\"w-full lg:w-1/3\">\n                <h2 class=\"text-xs uppercase tracking-widest text-white/60 mb-6\">05 / Engineering</h2>\n                <h3 class=\"text-4xl md:text-5xl font-normal tracking-tight-override mb-8\">UNCOMPROMISING<br/>ARCHITECTURE</h3>\n                <p class=\"text-lg text-white/50 mb-12\">Every vessel in our curated fleet represents the zenith of naval architecture. We analyze hydrodynamics, structural integrity, and propulsion efficiency.</p>\n                \n                <ul class=\"space-y-6 border-t border-white/10 pt-8\">\n                    <li class=\"flex items-start gap-4\">\n                        <div class=\"w-1.5 h-1.5 bg-white rounded-full mt-2\"></div>\n                        <div>\n                            <h4 class=\"text-base uppercase tracking-widest font-medium mb-1\">Hull Efficiency</h4>\n                            <p class=\"text-base text-white/40\">Optimized displacement for maximum range.</p>\n                        </div>\n                    </li>\n                    <li class=\"flex items-start gap-4\">\n                        <div class=\"w-1.5 h-1.5 bg-white/40 rounded-full mt-2\"></div>\n                        <div>\n                            <h4 class=\"text-base uppercase tracking-widest font-medium mb-1 text-white/60\">Hybrid Propulsion</h4>\n                            <p class=\"text-base text-white/40\">Next-generation silent cruising capabilities.</p>\n                        </div>\n                    </li>\n                </ul>\n            </div>\n            \n            <div class=\"w-full lg:w-2/3 relative h-[500px]\">\n                <!-- Schematic visual -->\n                <div class=\"absolute inset-0 border border-white/20 p-8 flex items-center justify-center bg-black/50 backdrop-blur-sm\">\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/c543a9e1-f226-4ced-80b0-feb8445a75b9_1600w.jpg\" class=\"w-full h-full object-cover opacity-30 grayscale contrast-150\" style=\"mix-blend-mode: screen;\" />\n                    \n                    <!-- Callouts -->\n                    <div class=\"absolute top-1/4 left-1/4 flex items-center gap-2\">\n                        <div class=\"w-2 h-2 bg-white rounded-full relative\"><div class=\"absolute inset-0 bg-white animate-ping rounded-full opacity-50\"></div></div>\n                        <div class=\"h-[1px] w-12 bg-white/50\"></div>\n                        <span class=\"text-[10px] uppercase tracking-widest font-mono\">Bridge Deck</span>\n                    </div>\n                    <div class=\"absolute bottom-1/3 right-1/4 flex items-center gap-2 flex-row-reverse\">\n                        <div class=\"w-2 h-2 bg-white rounded-full\"></div>\n                        <div class=\"h-[1px] w-24 bg-white/50\"></div>\n                        <span class=\"text-[10px] uppercase tracking-widest font-mono\">Engine Room</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 7: JOURNAL / NEWS -->\n    <section id=\"journal\" class=\"py-32 px-6 md:px-12 bg-[#0a0a0a]\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"flex justify-between items-end mb-16 border-b border-white/10 pb-8\">\n                <h2 class=\"text-4xl md:text-5xl font-normal tracking-tight-override\">JOURNAL</h2>\n                <a href=\"#\" class=\"text-xs uppercase tracking-widest hover:text-white/60 transition-colors\">View All Archive</a>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-16\">\n                <!-- Article 1 -->\n                <a href=\"#\" class=\"group block cursor-pointer\">\n                    <div class=\"relative h-64 mb-6 overflow-hidden bg-white/5\">\n                        <img src=\"https://images.unsplash.com/photo-1534008897995-27a23e859048?q=80&w=600&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-500\" />\n                    </div>\n                    <div class=\"flex justify-between items-center text-xs text-white/40 uppercase tracking-widest mb-3\">\n                        <span>Design</span>\n                        <span>Oct 12, 2023</span>\n                    </div>\n                    <h3 class=\"text-xl font-normal tracking-tight-override mb-3 group-hover:text-white/80 transition-colors\">The Evolution of Minimalist Interiors in Superyachts</h3>\n                    <div class=\"h-[1px] w-0 bg-white group-hover:w-full transition-all duration-500\"></div>\n                </a>\n\n                <!-- Article 2 -->\n                <a href=\"#\" class=\"group block cursor-pointer\">\n                    <div class=\"relative h-64 mb-6 overflow-hidden bg-white/5\">\n                        <img src=\"https://images.unsplash.com/photo-1505228395891-9a51e7e86bf6?q=80&w=600&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-500\" />\n                    </div>\n                    <div class=\"flex justify-between items-center text-xs text-white/40 uppercase tracking-widest mb-3\">\n                        <span>Destination</span>\n                        <span>Sep 28, 2023</span>\n                    </div>\n                    <h3 class=\"text-xl font-normal tracking-tight-override mb-3 group-hover:text-white/80 transition-colors\">Navigating the Uncharted: Svalbard Expedition</h3>\n                    <div class=\"h-[1px] w-0 bg-white group-hover:w-full transition-all duration-500\"></div>\n                </a>\n\n                <!-- Article 3 -->\n                <a href=\"#\" class=\"group block cursor-pointer\">\n                    <div class=\"relative h-64 mb-6 overflow-hidden bg-white/5\">\n                        <img src=\"https://images.unsplash.com/photo-1544551763-46a013bb70d5?q=80&w=600&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-500\" />\n                    </div>\n                    <div class=\"flex justify-between items-center text-xs text-white/40 uppercase tracking-widest mb-3\">\n                        <span>Market</span>\n                        <span>Sep 15, 2023</span>\n                    </div>\n                    <h3 class=\"text-xl font-normal tracking-tight-override mb-3 group-hover:text-white/80 transition-colors\">Q3 Market Analysis: The Rise of the Explorer Segment</h3>\n                    <div class=\"h-[1px] w-0 bg-white group-hover:w-full transition-all duration-500\"></div>\n                </a>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 8: CONTACT / INQUIRY -->\n    <section id=\"contact\" class=\"py-32 px-6 md:px-12 bg-[#050505]\">\n        <div class=\"max-w-5xl mx-auto flex flex-col md:flex-row gap-16\">\n            <div class=\"w-full md:w-1/2\">\n                <h2 class=\"text-xs uppercase tracking-widest text-white/60 mb-6\">07 / Connect</h2>\n                <h3 class=\"text-4xl md:text-5xl font-normal tracking-tight-override mb-8\">BEGIN YOUR<br/>JOURNEY</h3>\n                <p class=\"text-lg text-white/50 mb-12\">Our brokers are available worldwide to discuss your requirements with the utmost discretion.</p>\n                \n                <div class=\"space-y-6 text-sm text-white/70\">\n                    <div class=\"flex items-center gap-4\">\n                        <i data-lucide=\"map-pin\" class=\"w-4 h-4 opacity-50\"></i>\n                        <span>Monaco • London • Miami • Dubai</span>\n                    </div>\n                    <div class=\"flex items-center gap-4\">\n                        <i data-lucide=\"mail\" class=\"w-4 h-4 opacity-50\"></i>\n                        <span>private@northsea.com</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"w-full md:w-1/2\">\n                <form class=\"space-y-10\">\n                    <div class=\"relative\">\n                        <input type=\"text\" id=\"name\" class=\"w-full bg-transparent border-b border-white/20 py-4 text-lg focus:outline-none focus:border-white transition-colors peer placeholder-transparent\" placeholder=\"Name\">\n                        <label for=\"name\" class=\"absolute left-0 top-4 text-white/40 text-lg transition-all peer-focus:-top-4 peer-focus:text-xs peer-focus:uppercase peer-focus:tracking-widest peer-focus:text-white peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:uppercase peer-not-placeholder-shown:tracking-widest\">Full Name</label>\n                    </div>\n                    <div class=\"relative\">\n                        <input type=\"email\" id=\"email\" class=\"w-full bg-transparent border-b border-white/20 py-4 text-lg focus:outline-none focus:border-white transition-colors peer placeholder-transparent\" placeholder=\"Email\">\n                        <label for=\"email\" class=\"absolute left-0 top-4 text-white/40 text-lg transition-all peer-focus:-top-4 peer-focus:text-xs peer-focus:uppercase peer-focus:tracking-widest peer-focus:text-white peer-not-placeholder-shown:-top-4 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:uppercase peer-not-placeholder-shown:tracking-widest\">Email Address</label>\n                    </div>\n                    \n                    <!-- Custom Toggle -->\n                    <div class=\"flex items-center gap-4 pt-4\">\n                        <label class=\"relative inline-flex items-center cursor-pointer\">\n                            <input type=\"checkbox\" value=\"\" class=\"sr-only peer\">\n                            <div class=\"w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-white/40\"></div>\n                            <span class=\"ms-3 text-sm text-white/50\">Subscribe to private market updates</span>\n                        </label>\n                    </div>\n\n                    <button type=\"button\" class=\"w-full border border-white/30 py-4 mt-8 hover:bg-white hover:text-black transition-colors text-xs uppercase tracking-widest font-medium\">\n                        Submit Inquiry\n                    </button>\n                </form>\n            </div>\n        </div>\n    </section>\n\n    <!-- SECTION 9: FOOTER -->\n    <footer class=\"bg-black pt-32 pb-12 px-6 md:px-12 border-t border-white/10\">\n        <div class=\"max-w-7xl mx-auto\">\n            <!-- Huge Logo -->\n            <div class=\"w-full overflow-hidden mb-24 border-b border-white/10 pb-12 text-center md:text-left\">\n                <span class=\"text-[12vw] leading-none tracking-tight-override font-light text-white/90 uppercase block\">Northsea</span>\n            </div>\n\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-12 mb-24\">\n                <div class=\"col-span-2 md:col-span-1\">\n                    <h5 class=\"text-xs uppercase tracking-widest text-white/40 mb-6\">Company</h5>\n                    <ul class=\"space-y-4 text-base text-white/70\">\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">About Us</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">The Fleet</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Journal</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Careers</a></li>\n                    </ul>\n                </div>\n                <div class=\"col-span-2 md:col-span-1\">\n                    <h5 class=\"text-xs uppercase tracking-widest text-white/40 mb-6\">Services</h5>\n                    <ul class=\"space-y-4 text-base text-white/70\">\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Brokerage</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Charter</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Management</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">New Build</a></li>\n                    </ul>\n                </div>\n                <div class=\"col-span-2 md:col-span-2\">\n                    <h5 class=\"text-xs uppercase tracking-widest text-white/40 mb-6\">Global Offices</h5>\n                    <div class=\"grid grid-cols-2 gap-4 text-base text-white/70\">\n                        <div>\n                            <p class=\"text-white mb-1\">Monaco</p>\n                            <p class=\"text-sm opacity-50\">Port Hercules<br>MC 98000</p>\n                        </div>\n                        <div>\n                            <p class=\"text-white mb-1\">Miami</p>\n                            <p class=\"text-sm opacity-50\">Brickell Ave<br>FL 33131</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex flex-col md:flex-row justify-between items-center text-xs text-white/40 uppercase tracking-widest pt-8 border-t border-white/10\">\n                <p>&copy; 2024 Northsea Yachts Ltd. All rights reserved.</p>\n                <div class=\"flex gap-6 mt-4 md:mt-0\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Privacy</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Terms</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Instagram</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">LinkedIn</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- Interactive Scripts -->\n    <script>\n        // Initialize Lucide Icons\n        lucide.createIcons({\n            strokeWidth: 1.5\n        });\n\n        // Simple Mobile Menu Toggle\n        const menuBtn = document.getElementById('mobile-menu-btn');\n        let menuOpen = false;\n        \n        menuBtn.addEventListener('click', () => {\n            menuOpen = !menuOpen;\n            if(menuOpen) {\n                // In a real app, this would open a full-screen menu overlay\n                menuBtn.innerHTML = '<i data-lucide=\"x\" class=\"w-5 h-5\"></i>';\n                lucide.createIcons({ strokeWidth: 1.5 });\n            } else {\n                menuBtn.innerHTML = '<i data-lucide=\"menu\" class=\"w-5 h-5\"></i>';\n                lucide.createIcons({ strokeWidth: 1.5 });\n            }\n        });\n\n        // Horizontal Scroll Drag Logic for 'The Fleet' section\n        const slider = document.querySelector('.hide-scrollbar');\n        let isDown = false;\n        let startX;\n        let scrollLeft;\n\n        slider.addEventListener('mousedown', (e) => {\n            isDown = true;\n            slider.classList.add('active');\n            startX = e.pageX - slider.offsetLeft;\n            scrollLeft = slider.scrollLeft;\n        });\n        slider.addEventListener('mouseleave', () => {\n            isDown = false;\n            slider.classList.remove('active');\n        });\n        slider.addEventListener('mouseup', () => {\n            isDown = false;\n            slider.classList.remove('active');\n        });\n        slider.addEventListener('mousemove', (e) => {\n            if (!isDown) return;\n            e.preventDefault();\n            const x = e.pageX - slider.offsetLeft;\n            const walk = (x - startX) * 2; // Scroll-fast\n            slider.scrollLeft = scrollLeft - walk;\n        });\n    </script>\n</body>\n</html>","private":false,"user_id":"2676834c-60c2-439f-91ff-fb89bdd2b817","share_source_code":true}]